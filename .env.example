# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com/project/_/settings/api
# Use the new Publishable Key (sb_publishable_...) - the anon key is now legacy
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-publishable-key

# Optional: For server-side operations requiring elevated privileges
# Use Secret Key (sb_secret_...) - the service_role key is now legacy
# SUPABASE_SECRET_KEY=your-supabase-secret-key

# Production Deployment Notes:
# - For Railway: Add these as environment variables in the Railway dashboard
# - For Vercel: Add these in Project Settings > Environment Variables
# - Never commit .env.local to git (it's in .gitignore)
